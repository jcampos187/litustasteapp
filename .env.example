# ════════════════════════════════════════════════════════════════
# Litus Taste — Environment Variables
# ════════════════════════════════════════════════════════════════
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# For production, set these in your Vercel project settings:
#   https://vercel.com/YOUR_TEAM/litus-taste/settings/environment-variables
# ════════════════════════════════════════════════════════════════

# ─── Database ──────────────────────────────────────────────────
# Neon PostgreSQL connection string (projected database).
# Get it from: Neon Dashboard → Connection Details → PSQL
DATABASE_URL=

# ─── Authentication (Clerk) ────────────────────────────────────
# Clerk API keys. Get them from: Clerk Dashboard → API Keys
# IMPORTANT: Use Production keys, NOT Development keys, for production!
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk webhook signing secret for verifying webhook requests.
# Get it from: Clerk Dashboard → Webhooks → your endpoint → "Signing Secret"
CLERK_WEBHOOK_SECRET=

# Clerk routing configuration (keep these as-is unless customising paths)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/sign-up

# ─── Email (Resend) ────────────────────────────────────────────
# Resend API key. Get it from: https://resend.com/api-keys
RESEND_API_KEY=

# Admin email address — receives order notifications, new registration alerts, etc.
ADMIN_EMAIL=

# ─── File Uploads (UploadThing) ────────────────────────────────
# UploadThing credentials for meal & logo image uploads.
# Get them from: https://uploadthing.com/dashboard
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=

# ─── App URL ───────────────────────────────────────────────────
# The public URL of your deployment. Used in email links.
# Local:   http://localhost:3000
# Vercel:  https://litustasteapp.vercel.app
# Custom:  https://litustaste.com
NEXT_PUBLIC_APP_URL=

# ─── WhatsApp Cloud API (Optional) ─────────────────────────────
# WhatsApp Business integration for admin notifications.
#
# Setup guide:
#   1. Go to https://developers.facebook.com → Create App → Business → WhatsApp
#   2. Add the WhatsApp product, set up WABA, get Phone Number ID
#   3. Generate a permanent access token (Settings → Token)
#   4. Admin must send a "Hello" to the WhatsApp Business number first
#      (this opens the 24h service window for text messages)
#
# Phone Number ID from WhatsApp Business account
WHATSAPP_PHONE_NUMBER_ID=
# Permanent access token from Meta Developers
WHATSAPP_ACCESS_TOKEN=
# Admin's WhatsApp number in international format (e.g., 506XXXXXXXX for Costa Rica)
WHATSAPP_TO_NUMBER=
